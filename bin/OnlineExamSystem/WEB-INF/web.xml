<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>OnlineExamSystem</display-name>

    <servlet>
        <servlet-name>AddExamServlet</servlet-name>
        <servlet-class>servlet.AddExamServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddExamServlet</servlet-name>
        <url-pattern>/addExam</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddQuestionServlet</servlet-name>
        <servlet-class>servlet.AddQuestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddQuestionServlet</servlet-name>
        <url-pattern>/addQuestion</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetExamsServlet</servlet-name>
        <servlet-class>servlet.GetExamsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetExamsServlet</servlet-name>
        <url-pattern>/getExams</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetQuestionsServlet</servlet-name>
        <servlet-class>servlet.GetQuestionsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetQuestionsServlet</servlet-name>
        <url-pattern>/getQuestions</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetResultsServlet</servlet-name>
        <servlet-class>servlet.GetResultsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetResultsServlet</servlet-name>
        <url-pattern>/getResults</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SaveResultServlet</servlet-name>
        <servlet-class>servlet.SaveResultServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveResultServlet</servlet-name>
        <url-pattern>/saveResult</url-pattern>
    </servlet-mapping>
</web-app>